# ============================================================
# 测试环境配置 (staging)
# 运行方式: npm run build:stage
# Vue CLI 在 build --mode staging 时自动加载 .env.staging
# ============================================================

# 页面标题
VUE_APP_TITLE = 书城管理系统(测试)

# 环境标识
BABEL_ENV = production
NODE_ENV = production
ENV = 'staging'

# 测试环境 API 前缀
VUE_APP_BASE_API = '/stage-api'

# 测试环境后端 API 地址
VUE_APP_BASE_URL = 'http://test-api.xhbookstore.com'
