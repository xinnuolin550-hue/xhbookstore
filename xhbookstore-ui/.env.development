# ============================================================
# 本地开发环境配置 (dev)
# 运行方式: npm run dev
# Vue CLI 在 serve 时自动加载 .env.development
# ============================================================

# 页面标题
VUE_APP_TITLE = 书城管理系统

# 环境标识
ENV = 'development'
NODE_ENV = development

# 开发环境 API 前缀
VUE_APP_BASE_API = '/dev-api'

# 开发环境后端 API 地址（代理目标）
VUE_APP_BASE_URL = 'http://localhost:8090'

# 路由懒加载
VUE_CLI_BABEL_TRANSPILE_MODULES = true
