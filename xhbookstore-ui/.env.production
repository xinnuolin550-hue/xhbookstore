# ============================================================
# 生产环境配置 (production)
# 运行方式: npm run build:prod
# Vue CLI 在 build 时自动加载 .env.production
# ============================================================

# 页面标题
VUE_APP_TITLE = 书城管理系统

# 环境标识
ENV = 'production'
NODE_ENV = production

# 生产环境 API 前缀
VUE_APP_BASE_API = '/prod-api'

# 生产环境后端 API 地址
VUE_APP_BASE_URL = 'http://api.xhbookstore.com'
