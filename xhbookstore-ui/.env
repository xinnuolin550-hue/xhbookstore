# ============================================================
# 公共环境配置（所有模式的基础配置）
# 各模式可通过 .env.[mode] 覆盖此处的配置项
# 加载顺序: .env → .env.local → .env.[mode] → .env.[mode].local
# ============================================================

# 页面标题（默认）
VUE_APP_TITLE = 书城管理系统

# API 前缀（默认生产环境，dev/staging 模式会覆盖）
VUE_APP_BASE_API = '/prod-api'
